#!/usr/bin/env bash
#
# adderall — keep your Mac awake, even with the lid closed.
# https://github.com/Carlos-err406/adderall
#
# Combines `caffeinate` (block display/system/idle sleep) with
# `pmset disablesleep 1` (the bit that allows clamshell-closed operation).
# State is tracked by a pidfile so every integration agrees on on/off.

PIDFILE="${TMPDIR:-/tmp}/adderall.pid"
UNTILFILE="${TMPDIR:-/tmp}/adderall.until"
PILL="💊"
ZZZ="😴"

# Exit 0 while keeping-awake is active, else non-zero. No output.
_active() {
  [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE" 2>/dev/null)" 2>/dev/null
}

# Parse "30m" / "2h" / "90s" / bare-minutes -> seconds (echoed). Non-zero on bad input.
_parse_duration() {
  local d="$1" n unit
  [ -z "$d" ] && return 1
  case "$d" in
    *h) unit=3600; n="${d%h}" ;;
    *m) unit=60;   n="${d%m}" ;;
    *s) unit=1;    n="${d%s}" ;;
    *)  unit=60;   n="$d" ;;          # bare number = minutes
  esac
  case "$n" in ''|*[!0-9]*) return 2 ;; esac
  echo $(( n * unit ))
}

# Seconds -> "1h30m" / "45m" / "20s".
_human() {
  local s="$1" h m
  h=$(( s / 3600 )); m=$(( (s % 3600) / 60 ))
  if   [ "$h" -gt 0 ] && [ "$m" -gt 0 ]; then echo "${h}h${m}m"
  elif [ "$h" -gt 0 ]; then echo "${h}h"
  elif [ "$m" -gt 0 ]; then echo "${m}m"
  else echo "${s}s"
  fi
}

# Echo human-readable time left on a timed run (e.g. "1h47m"), else nothing.
_remaining() {
  [ -f "$UNTILFILE" ] || return 0
  local now deadline rem
  now="$(date +%s)"; deadline="$(cat "$UNTILFILE" 2>/dev/null || echo 0)"
  rem=$(( deadline - now ))
  [ "$rem" -gt 0 ] && _human "$rem"
}

# When the timed caffeinate exits, restore sleep — but only if this session is
# still the active one (the user hasn't toggled it since).
_schedule_off() {
  # shellcheck disable=SC2016  # $1/$2/$3 are args for the inner bash, not parent vars
  nohup bash -c '
    pid="$1"; pf="$2"; uf="$3"
    while kill -0 "$pid" 2>/dev/null; do sleep 2; done
    [ "$(cat "$pf" 2>/dev/null)" = "$pid" ] || exit 0
    rm -f "$pf" "$uf"
    sudo /usr/bin/pmset disablesleep 0 >/dev/null 2>&1
  ' _ "$1" "$PIDFILE" "$UNTILFILE" >/dev/null 2>&1 &
}

_on() {
  local dur="$1" secs="" oldpid="" pid wasActive=false hadTimer=false
  if [ -n "$dur" ]; then
    if ! secs="$(_parse_duration "$dur")"; then
      echo "adderall: invalid duration '$dur' — use 30m, 2h, 90s, or a number of minutes" >&2
      return 2
    fi
  fi
  if _active; then
    wasActive=true
    oldpid="$(cat "$PIDFILE" 2>/dev/null)"
    [ -f "$UNTILFILE" ] && hadTimer=true
  fi

  # Already on with nothing to change (no timer requested, none running): no-op.
  if $wasActive && [ -z "$secs" ] && ! $hadTimer; then
    echo "$PILL adderall already ON (PID $oldpid)"
    return 0
  fi

  # (Re)start caffeinate. Write the new pid BEFORE killing the old one so the old
  # timer's watcher sees a changed pidfile and exits without restoring sleep —
  # letting us re-arm/clear the timer in place without toggling pmset.
  if [ -n "$secs" ]; then nohup caffeinate -disu -t "$secs" >/dev/null 2>&1 &
  else                    nohup caffeinate -disu            >/dev/null 2>&1 &
  fi
  pid=$!
  echo "$pid" > "$PIDFILE"
  if [ -n "$oldpid" ]; then kill "$oldpid" 2>/dev/null || true; fi

  if [ -n "$secs" ]; then echo $(( $(date +%s) + secs )) > "$UNTILFILE"; else rm -f "$UNTILFILE"; fi
  sudo /usr/bin/pmset disablesleep 1   # absolute path: matches the sudoers rule even in a minimal PATH (Raycast, etc.)
  [ -n "$secs" ] && _schedule_off "$pid"

  if $wasActive; then
    if [ -n "$secs" ]; then
      echo "$PILL adderall timer set to $(_human "$secs") — still ON (PID $pid)"
    else
      echo "$PILL adderall timer cleared — staying ON indefinitely (PID $pid)"
    fi
  elif [ -n "$secs" ]; then
    echo "$PILL adderall ON for $(_human "$secs") — sleep blocked, even with the lid closed (PID $pid)"
  else
    echo "$PILL adderall ON — sleep blocked, even with the lid closed (PID $pid)"
  fi
}

_off() {
  if [ -f "$PIDFILE" ]; then
    kill "$(cat "$PIDFILE" 2>/dev/null)" 2>/dev/null || true
    rm -f "$PIDFILE"
  fi
  rm -f "$UNTILFILE"
  pkill -x caffeinate 2>/dev/null || true   # fallback for a stale pidfile
  sudo /usr/bin/pmset disablesleep 0         # absolute path: matches the sudoers rule even in a minimal PATH
  echo "$ZZZ adderall OFF — normal sleep restored"
}

# One-time setup: install the scoped, passwordless sudoers rule so toggling never
# prompts for a password. Used by Homebrew installs (brew can't run sudo at install).
_setup() {
  local user tmp
  user="$(whoami)"
  tmp="$(mktemp)"
  {
    echo "# adderall — passwordless clamshell-sleep toggle"
    echo "# https://github.com/Carlos-err406/adderall"
    echo "$user ALL=(root) NOPASSWD: /usr/bin/pmset disablesleep 0, /usr/bin/pmset disablesleep 1"
  } > "$tmp"
  if visudo -cf "$tmp" >/dev/null 2>&1; then
    echo "Installing the passwordless sudoers rule (needs your password once)…"
    if sudo install -m 0440 -o root -g wheel "$tmp" /etc/sudoers.d/adderall; then
      echo "✓ adderall can now toggle sleep without a password."
    else
      echo "⚠️  couldn't install the sudoers rule." >&2
    fi
  else
    echo "⚠️  generated sudoers rule failed validation; not installed." >&2
  fi
  rm -f "$tmp"
  echo "Menu bar / prompt / status line / Raycast integrations:"
  echo "  https://github.com/Carlos-err406/adderall#integrations"
}

_status() {
  local extra="" rem
  if _active; then
    rem="$(_remaining)"
    [ -n "$rem" ] && extra=" — auto-off in $rem"
    echo "$PILL adderall is ON${extra} — your Mac won't sleep, even with the lid closed (PID $(cat "$PIDFILE"))"
    echo "   run 'adderall off' to restore normal sleep"
  else
    echo "$ZZZ adderall is OFF — normal sleep behavior"
    echo "   run 'adderall on' (or 'adderall on 2h') to keep it awake, even with the lid closed"
  fi
}

_usage() {
  cat <<USAGE
adderall — keep your Mac awake, even with the lid closed.

usage:
  adderall                 show status (default)
  adderall on [duration]   keep awake; set/CHANGE the auto-off timer (30m, 2h, 90s) even while on
  adderall off             restore normal sleep
  adderall toggle [dur]    flip on/off (duration applies when turning on)
  adderall active          exit 0 if on, 1 if off — no output (for prompts/scripts)
  adderall remaining       time left on a timed run, e.g. "1h47m" (for menu bars)
  adderall setup           one-time: install the passwordless sudoers rule
  adderall help            show this help

duration: a bare number is minutes; or suffix with s / m / h.
state files: \${TMPDIR:-/tmp}/adderall.pid and adderall.until
USAGE
}

case "${1:-status}" in
  on)             _on "$2" ;;
  off)            _off ;;
  toggle)         if _active; then _off; else _on "$2"; fi ;;
  status|"")      _status ;;
  active)         _active; exit $? ;;
  remaining)      _remaining ;;
  setup)          _setup ;;
  help|-h|--help) _usage ;;
  *)              echo "adderall: unknown command '$1'" >&2; echo >&2; _usage >&2; exit 2 ;;
esac
